# Copy this file to `.env` and adjust values for your local environment.
# `.env` is gitignored — real values never hit the repo.

# ── PostgreSQL ───────────────────────────────────────
POSTGRES_DB=bookecom
POSTGRES_USER=bookecom
POSTGRES_PASSWORD=change_me_for_local_dev
# Host-side port to expose the DB on (container itself always listens on 5432).
# Change this if you already have another Postgres running on your machine.
POSTGRES_HOST_PORT=5433
